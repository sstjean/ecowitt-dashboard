# deploy/kiosk/.env.example — operator-supplied provisioning inputs.
#
# Copy to deploy/kiosk/.env (which is .gitignored) and fill in real values:
#   cp deploy/kiosk/.env.example deploy/kiosk/.env
# NEVER commit a real PSK. Only this placeholder example is tracked.

# --- Required ---------------------------------------------------------------
# Main trusted WLAN the kiosk joins (and only this one).
KIOSK_WIFI_SSID=marbles
# WPA2 pre-shared key for the main WLAN. SECRET — replace the placeholder.
KIOSK_WIFI_PSK=<your-wpa2-psk>

# --- Optional ---------------------------------------------------------------
# Isolated IoT WLAN that must never be auto-joined (if in range).
KIOSK_IOT_SSID=Marbles-iot
# Dashboard URL the kiosk displays full-screen.
KIOSK_URL=http://192.168.10.5:8090/
# Local unprivileged user the kiosk session runs as.
KIOSK_USER=kiosk
KIOSK_UID=1001
