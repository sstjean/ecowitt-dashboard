# deploy/watchdog/.env.example
# Tracked template for the watchdog config. Copy to deploy/watchdog/.env
# (gitignored) for provision-time overrides, or edit the installed
# /etc/ecowitt-watchdog/watchdog.env to retune at runtime.
#
# Every knob has a pinned default (data-model.md §2); uncomment only what you
# want to change. All values are sourced as shell env vars.

# --- Identity / locations ---------------------------------------------------
# Docker Compose project prefix (container names are <project>-<svc>-1).
#WATCHDOG_PROJECT=ecowitt-dashboard
# Read-only path to the app SQLite DB on the host (named-volume mount).
#WATCHDOG_DB_PATH=/var/lib/docker/volumes/ecowitt-dashboard_sqlite-data/_data/ecowitt.sqlite
# Watchdog restart-state file (atomic JSON).
#WATCHDOG_STATE_PATH=/var/lib/ecowitt-watchdog/state.json
# Base URL for the api/web HTTP probes.
#WATCHDOG_BASE_URL=http://localhost:8090

# --- Health thresholds ------------------------------------------------------
# Poller is "stale" (unhealthy) when the newest reading is older than this.
#WATCHDOG_POLLER_MAX_AGE_SECONDS=300
# Consecutive failed api/web probes required before a restart.
#WATCHDOG_HTTP_FAIL_THRESHOLD=3

# --- Restart governor -------------------------------------------------------
# Minimum seconds between restarts of the same service.
#WATCHDOG_RESTART_COOLDOWN_SECONDS=600
# Rolling window for the per-service restart cap.
#WATCHDOG_RESTART_WINDOW_SECONDS=3600
# Max restarts of one service within the window before backing off (loud log).
#WATCHDOG_RESTART_WINDOW_CAP=3

# --- Timer ------------------------------------------------------------------
# How often the watchdog fires. NOTE: changing this requires re-running
# provision.sh — the value is substituted into the .timer at install time
# (a systemd .timer cannot read this EnvironmentFile).
#WATCHDOG_INTERVAL_SECONDS=60
