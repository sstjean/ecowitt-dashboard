# Ingestion / runtime configuration (FR-055 — NO values committed; copy to .env.local)

# --- Poller ---
GATEWAY_BASE_URL=
POLL_CADENCE_SECONDS=30
SQLITE_PATH=

# --- LiveMock (cloud dev source; used with docker-compose.livemock.yml) ---
# POLLER_SOURCE=gateway (default) keeps production on the LAN gateway.
# Set POLLER_SOURCE=cloud to pull real readings from the Ecowitt cloud API.
# The three ECOWITT_* keys are required only when POLLER_SOURCE=cloud.
POLLER_SOURCE=gateway
ECOWITT_APP_KEY=
ECOWITT_API_KEY=
ECOWITT_MAC=
ECOWITT_API_BASE_URL=https://api.ecowitt.net

# --- API ---
HOUSEHOLD_LAT=
HOUSEHOLD_LON=
RAIN_FULL_SCALE_IN=4.0
BARO_TREND_WINDOW_HOURS=3
BARO_STEADY_EPSILON_HPA=0.3
NWS_USER_AGENT=
NWS_CACHE_TTL_SECONDS=600
NWS_STALE_AFTER_SECONDS=3600
NWS_TIMEOUT_MS=5000

# --- Web ---
UI_REFRESH_SECONDS=10

# --- Compose / deployment (optional; sensible defaults in docker-compose.yml) ---
WEB_PORT=8080
BACKUP_HOST_DIR=./backups
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
